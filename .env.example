# GCS input base path — override to redirect all 14 hazard input Zarrs at once
# GCS_INPUT_BASE={gs://climate_data/PHYSICAL_HAZARDS_WORKING_FOLDER}

# GCS output paths — override to real paths
GCS_OUTPUT_ZARR_BASE=gs://climate_data/production_test/hazard_scores
GCS_CSV_OUTPUT=gs://climate_data/production_test/aggregations
GCS_COMBINED_OUTPUT=gs://climate_data/production_test/aggregations/combined
GCS_GADM_PARQUET_BASE=gs://climate_data/GADM/parquet
GCS_TMP_BASE=gs://climate_data/production_test/tmp

# GADM reference data paths
GCS_GADM_SOURCE_L0=gs://climate_data/GADM/GADM/gadm410/gadm_410levels__adm_0.gpkg
GCS_GADM_SOURCE_L1=gs://climate_data/GADM/GADM/gadm410/gadm_410levels__adm_1.gpkg
GCS_GADM_COASTLINE=gs://climate_data/GADM/GADM/Coastline/hyd_glo_msk_30s.tif
GCS_GADM_ADM0=gs://climate_data/GADM/parquet/adm0.parquet
GCS_GADM_ADM1=gs://climate_data/GADM/parquet/adm1.parquet
GCS_GADM_ADM1_BASE=gs://climate_data/GADM/parquet/adm1
GCS_GADM_ADM2_BASE=gs://climate_data/GADM/parquet/adm2
